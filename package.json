{
  "name": "@g-signal/workspace",
  "version": "1.0.0",
  "description": "G-Signal Monorepo Workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "npx husky",
    "build": "pnpm -r run build",
    "dev": "pnpm -r run dev",
    "clean": "rm -rf dist node_modules && pnpm -r exec rm -rf dist node_modules",
    "publish:dry": "node scripts/publish.js --dry-run",
    "publish:all": "node scripts/publish.js"
  },
  "keywords": [
    "signal",
    "reactive",
    "state-management",
    "monorepo"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@gitborlando/utils": "^3.1.0",
    "@types/node": "^24.0.10",
    "@types/react": "^18.0.0",
    "@vitest/ui": "^3.2.4",
    "chokidar": "^3.5.3",
    "defu": "^6.1.4",
    "glob": "^10.3.10",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "nanoid": "^5.1.5",
    "prettier": "^3.6.2",
    "pretty-quick": "^4.2.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "prettier": {
    "printWidth": 85,
    "jsxBracketSameLine": true,
    "useTabs": false,
    "tabWidth": 2,
    "semi": false,
    "singleQuote": true,
    "jsxSingleQuote": true
  }
}
